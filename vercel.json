{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/app.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1",
    "SHAZAM_SAMPLE_SECONDS": "8",
    "SHAZAM_WARMUP_SECONDS": "1",
    "SHAZAM_ATTEMPTS": "1",
    "TRACK_CACHE_TTL": "90",
    "PLAYER_USES_PROXY": "0"
  },
  "regions": [
    "fra1"
  ]
}
